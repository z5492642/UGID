]

# ------------------------------------------------------------------
# 3.  Pre‑compute column‑wise min and max
# ------------------------------------------------------------------
col_min = orig_df[feature_cols].min().to_numpy()   # shape (6,)
col_max = orig_df[feature_cols].max().to_numpy()   # shape (6,)

# ------------------------------------------------------------------
# 4.  A small helper that works for a single vector *or* a matrix
# ------------------------------------------------------------------
def inverse_min_max(x_scaled: np.ndarray,
                    vmin: np.ndarray = col_min,
                    vmax: np.ndarray = col_max) -> np.ndarray:
    """
    Convert scaled values in [0,1]^d back to the original units.

    Parameters
    ----------
    x_scaled : (n_samples, d) or (d,) ndarray
        Scaled feature values in the unit hyper‑cube.
    vmin, vmax : (d,) ndarray
        Column‑wise minima and maxima from the *original* data set.

    Returns
    -------
    x_orig : ndarray with the same shape as x_scaled
        Rescaled feature values.
    """
    x_scaled = np.asarray(x_scaled, dtype=float)
    return x_scaled * (vmax - vmin) + vmin



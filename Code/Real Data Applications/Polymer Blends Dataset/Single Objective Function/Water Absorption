#GPR Regression + Negative Log Marginal Likelihood

def gp_regression_noisy(X, y, k, x_star, var_f, var_n, l):
    """
    Predictive mean & variance for GPR with noise variance var_n.
    X, y: training data, shape (N, d), (N,)
    x_star: test location(s), shape (M, d)
    var_f: signal variance
    var_n: noise variance
    l: length scales (array)
    """
    # Cov on training
    Kxx = k(X, X, var_f, l) + var_n * np.eye(X.shape[0])
    Lxx = np.linalg.cholesky(Kxx)
    a = np.linalg.solve(Lxx.T, np.linalg.solve(Lxx, y))

    # Cross-cov
    Kxs = k(X, x_star, var_f, l)
    mu = Kxs.T @ a  # predictive mean(s)

    # Predictive var
    v = np.linalg.solve(Lxx, Kxs)
    Kss = k(x_star, x_star, var_f, l)
    var = Kss - v.T @ v

    return mu, var

def f_opt(params, *args):
    """
    Negative log marginal likelihood objective for L-BFGS.
    params = [var_f, l1, l2, ..., var_n]
    """
    X, y, k = args
    d = X.shape[1]
    var_f = params[0]
    var_n = params[-1]
    lengthscales = params[1:-1]

    # Cov with noise
    Kxx = k(X, X, var_f, lengthscales) + var_n*np.eye(X.shape[0])
    Lxx = np.linalg.cholesky(Kxx)
    a = np.linalg.solve(Lxx.T, np.linalg.solve(Lxx, y))
    # Negative log marginal likelihood
    n = X.shape[0]
    logdetK = 2.0 * np.sum(np.log(np.diag(Lxx)))  # log(det(Kxx)) from Cholesky
    return 0.5 * y.T @ a + 0.5 * logdetK + 0.5 * n * np.log(2.0 * np.pi)


# Function to run particles through the GPR model and get predicted responses and their standard deviations
def evaluate_particles_with_sd(particles, gpr_params):
    X_sample, Y_sample, kernel, var_f, var_n, l = gpr_params
    predicted_responses = []
    predicted_stds = []  # To store the standard deviations

    for particle in particles:
        mu, var = gp_regression_noisy(X_sample, Y_sample, kernel, np.array([particle]), var_f, var_n, l)
        predicted_responses.append(mu[0])  # Store the predicted response (mean)
        predicted_stds.append(np.sqrt(var[0, 0]))  # Store the standard deviation (sqrt of variance)

    return np.array(predicted_responses).flatten(), np.array(predicted_stds).flatten()  # Ensure they are 1D arrays

def objective_function(x, gpr_params, y_target, alpha=5):
    """
    Objective = (GP mean at x - y_target)^2
    We want to minimize this w.r.t. x in [0,1]^2
    """
    X_sample, Y_sample, kernel_func, var_f, var_n, l = gpr_params
    mu, var = gp_regression_noisy(X_sample, Y_sample, kernel_func,
                                  np.array([x]), var_f, var_n, l)

    #sigma = np.sqrt(var[0,0])
    sigma = var[0,0]
    return (mu[0] - y_target)**2 + alpha*sigma

def run_pso(
    init_positions,
    gpr_params,
    y_target,
    alpha=5.0,
    n_steps=20,
    w=0.5,  # inertia
    c1=1.0, # personal
    c2=1.0, # social
    seed=123
):
    """
    Run PSO starting from 'init_positions' (shape=(K1,2)).
    Return final positions (shape=(K1,2)).
    """
    np.random.seed(seed)
    n_particles = init_positions.shape[0]
    d = init_positions.shape[1]

    # Initialize swarm
    positions = init_positions.copy()
    velocities = np.zeros_like(positions)

    # Evaluate initial objective
    fitness = np.array([
        objective_function(pos, gpr_params, y_target, alpha) for pos in positions
    ])

    personal_best_positions = positions.copy()
    personal_best_fitness = fitness.copy()

    gbest_idx = np.argmin(personal_best_fitness)
    global_best_position = personal_best_positions[gbest_idx].copy()
    global_best_fitness = personal_best_fitness[gbest_idx]

    # PSO iteration
    for step in range(n_steps):
        for i in range(n_particles):
            r1, r2 = np.random.rand(), np.random.rand()
            velocities[i] = (
                w*velocities[i]
                + c1*r1*(personal_best_positions[i] - positions[i])
                + c2*r2*(global_best_position - positions[i])
            )
            positions[i] += velocities[i]
            # clamp to [0,1]
            positions[i] = np.clip(positions[i], 0, 1)

            # evaluate
            fit_val = objective_function(positions[i], gpr_params, y_target, alpha)
            if fit_val < personal_best_fitness[i]:
                personal_best_positions[i] = positions[i].copy()
                personal_best_fitness[i] = fit_val

        gbest_idx = np.argmin(personal_best_fitness)
        if personal_best_fitness[gbest_idx] < global_best_fitness:
            global_best_position = personal_best_positions[gbest_idx].copy()
            global_best_fitness = personal_best_fitness[gbest_idx]

    # Return the final swarm positions
    return global_best_position

def sample_particles_from_training_data(training_data, K1, seed=123):
    """
    Picks K1 points from training_data (with or without replacement).
    Adds small random noise so they're not identical.
    """
    np.random.seed(seed)
    n_train = training_data.shape[0]
    if K1 <= n_train:
        idxs = np.random.choice(n_train, K1, replace=False)
    else:
        idxs = np.random.choice(n_train, K1, replace=True)

    particles = training_data[idxs].copy()
    # small jitter so they're not identical
    particles += 0.01 * (np.random.rand(*particles.shape) - 0.5)
    particles = np.clip(particles, 0, 1)
    return particles

def smc_inverse_regression_modified_with_gpr_sd(
    X_sample, Y_sample, kernel_func,
    y_target,
    K1=1000,
    random_seed=123,
    n_iterations=50,
    pso_steps=20,     # how many PSO iterations per outer loop
    alpha=5.0
):
    x0 = [1] + [1]*28 + [0.001]
    bounds = [(1e-3, None)] + [(1e-3,1.0)]*28 + [(1e-5, None)]
    args = (X_sample, Y_sample, kernel_func)
    res = opt.fmin_l_bfgs_b(f_opt, x0, args=args, approx_grad=True, bounds=bounds)

    var_f_optimized = res[0][0]
    var_n_optimized = res[0][-1]
    l_optimized = res[0][1:-1]

    # GPR parameter tuple
    gpr_params = (X_sample, Y_sample, kernel_func, var_f_optimized, var_n_optimized, l_optimized)

    # Store the best solution from each iteration
    best_solutions_each_iter = []
    best_solutions_stds_each_iter = []

    for iter_idx in range(n_iterations):

        # Step 1: pick K1 initial positions from training data
        init_particles = sample_particles_from_training_data(
            X_sample, K1, seed=(random_seed + iter_idx)
        )

        # Step 2: run PSO on these K1 points
        best_sol = run_pso(
            init_positions=init_particles,
            gpr_params=gpr_params,
            y_target=y_target,
            alpha=alpha,
            n_steps=pso_steps,
            w=0.5, c1=1.0, c2=1.0,
            seed=(random_seed + iter_idx)
        )

        # Evaluate and store info about that best solution
        pred, std_ = evaluate_particles_with_sd(
            np.array([best_sol]),
            gpr_params
        )
        best_solutions_each_iter.append(best_sol)
        best_solutions_stds_each_iter.append(std_[0])

    # For convenience, return the final arrays
    return (
        var_f_optimized, l_optimized, var_n_optimized,
        np.array(best_solutions_each_iter),           # shape (n_iterations, 2)
        np.array(best_solutions_stds_each_iter)       # shape (n_iterations,)
    )

def get_responses_for_final_particles(final_particles, gpr_params):
    """
    Predict the response values for a set of particles using the GPR model.
    final_particles: array of shape (K2, 2)
    gpr_params: (X_sample, Y_sample, kernel_func, var_f, var_n, l)
    """
    X_sample, Y_sample, kernel_func, var_f, var_n, l = gpr_params
    responses = []
    std_dev_res = []
    for particle in final_particles:
        mu, var = gp_regression_noisy(X_sample, Y_sample, kernel_func,
                                    np.array([particle]), var_f, var_n, l)
        responses.append(mu[0])
        std_dev_res.append(np.sqrt(var[0,0]))
    return np.array(responses)


#GPR Regression + Negative Log Marginal Likelihood

def gp_regression_noisy(X, y, k, x_star, var_f, var_n, l):
    """
    Predictive mean & variance for GPR with noise variance var_n.
    X, y: training data, shape (N, d), (N,)
    x_star: test location(s), shape (M, d)
    var_f: signal variance
    var_n: noise variance
    l: length scales (array)
    """
    # Cov on training
    Kxx = k(X, X, var_f, l) + var_n * np.eye(X.shape[0])
    Lxx = np.linalg.cholesky(Kxx)
    a = np.linalg.solve(Lxx.T, np.linalg.solve(Lxx, y))

    # Cross-cov
    Kxs = k(X, x_star, var_f, l)
    mu = Kxs.T @ a  # predictive mean(s)

    # Predictive var
    v = np.linalg.solve(Lxx, Kxs)
    Kss = k(x_star, x_star, var_f, l)
    var = Kss - v.T @ v

    return mu, var

def f_opt(params, *args):
    """
    Negative log marginal likelihood objective for L-BFGS.
    params = [var_f, l1, l2, ..., var_n]
    """
    X, y, k = args
    d = X.shape[1]
    var_f = params[0]
    var_n = params[-1]
    lengthscales = params[1:-1]

    # Cov with noise
    Kxx = k(X, X, var_f, lengthscales) + var_n*np.eye(X.shape[0])
    Lxx = np.linalg.cholesky(Kxx)
    a = np.linalg.solve(Lxx.T, np.linalg.solve(Lxx, y))
    # Negative log marginal likelihood
    n = X.shape[0]
    logdetK = 2.0 * np.sum(np.log(np.diag(Lxx)))  # log(det(Kxx)) from Cholesky
    return 0.5 * y.T @ a + 0.5 * logdetK + 0.5 * n * np.log(2.0 * np.pi)


def sample_from_unit_cube(n_samples, n_features=6, seed=123):
    np.random.seed(seed)
    return np.random.uniform(0, 1, (n_samples, n_features))

def evaluate_particles_with_sd(particles, gpr_params):
    """
    Evaluate GPR mean & std for each particle.
    Returns predicted_responses, predicted_stds.
    """
    X_sample, Y_sample, kernel_func, var_f, var_n, l = gpr_params
    preds = []
    stds = []
    for p in particles:
        mu, var = gp_regression_noisy(X_sample, Y_sample, kernel_func,
                                      np.array([p]), var_f, var_n, l)
        preds.append(mu[0])
        stds.append(np.sqrt(var[0,0]))
    return np.array(preds), np.array(stds)

def get_responses_for_final_particles(final_particles, gpr_params):
    """
    Predict the response values for a set of particles using the GPR model.
    final_particles: array of shape (K2, 2)
    gpr_params: (X_sample, Y_sample, kernel_func, var_f, var_n, l)
    """
    X_sample, Y_sample, kernel_func, var_f, var_n, l = gpr_params
    responses = []
    std_dev_res = []
    for particle in final_particles:
        mu, var = gp_regression_noisy(X_sample, Y_sample, kernel_func,
                                    np.array([particle]), var_f, var_n, l)
        responses.append(mu[0])
        std_dev_res.append(np.sqrt(var[0,0]))
    return np.array(responses), np.array(std_dev_res)

def run_nsga2_refinement(initial_points, X_train, y_train,
                         kernel_func, var_f, var_n, lengthscales,
                         y_target=15.0,
                         n_gen=30,
                         seed=123):
    """
    Runs a short NSGA-II optimization with an initial population = initial_points.
    Minimizes 2 objectives:
       f1(x) = (mu(x) - y_target)^2
       f2(x) = std(x)
    Domain: x in [0,1]^2

    Returns final Pareto solutions (res.X) and objective values (res.F).
    """

    # 1) Define the objective functions as python callables
    def f1(pop_X):

      mu, var = gp_regression_noisy(X_train, y_train,
                                    kernel_func,
                                    pop_X,
                                    var_f, var_n, lengthscales)
      mu = mu.ravel()
      return (mu - y_target)**2

    def f2(pop_X):
      mu, var = gp_regression_noisy(X_train, y_train,
                                    kernel_func,
                                    pop_X,
                                    var_f, var_n, lengthscales)
      var_diag = np.diag(var)
      return np.sqrt(var_diag)

    # 2) Create a FunctionalProblem with 2 objectives
    problem = FunctionalProblem(
        n_var=6,
        objs=[f1, f2],
        xl=[0.0]*6,
        xu=[1.0]*6
    )

    # 3) Create an initial population from initial_points
    #    'initial_points' is shape (K2, 2), so we will let pop_size = K2
    from pymoo.core.population import Population
    pop_init = Population.new("X", initial_points)

    # 4) Define the NSGA-II algorithm with that initial population
    from pymoo.algorithms.moo.nsga2 import NSGA2
    algorithm = NSGA2(pop_size=len(initial_points),
                      sampling=pop_init)  # override initial population

    # 5) Termination: run for n_gen generations
    from pymoo.termination import get_termination
    termination = get_termination("n_gen", n_gen)

    # 6) Run the optimization
    from pymoo.optimize import minimize
    res = minimize(problem,
                   algorithm,
                   termination,
                   seed=seed,
                   verbose=False)

    return res.X, res.F

def smc_inverse_regression_modified_with_gpr_sd_multiobj(
    X_sample, Y_sample, kernel_func,
    y_target=15,
    K1=1000,
    n_gen_nsga2=20,
    random_seed=123,
    n_iterations=50,
):

    np.random.seed(random_seed)

    #x0 = [1] + [.35, 0.15, 0.55, 0.45, 0.3, 0.12] + [0.001]
    x0 = [1] + [0.5, 0.5, 0.5, 0.5, 0.5, 0.5] + [0.01]
    bounds = [(1e-3, None)] + [(1e-3,1.0)]*6 + [(1e-5, None)]
    args = (X_sample, Y_sample, kernel_func)
    res = opt.fmin_l_bfgs_b(f_opt, x0, args=args, approx_grad=True, bounds=bounds)

    var_f_optimized = res[0][0]
    var_n_optimized = res[0][-1]
    l_optimized = res[0][1:-1]

    final_solutions_all = []
    final_obj_all = []
    sd_all_iterations_mo = []
    min_sd_all_iterations_mo = []

    for iter_idx in range(n_iterations):

        # Step 1: sample K1 points from [0,1]^2
        particles = sample_from_unit_cube(K1, n_features=6, seed=random_seed + iter_idx)

        # Step 5: Instead of local gradient optimization, we do NSGA-II refinement
        # starting from topK_particles
        final_solutions, final_obj = run_nsga2_refinement(
            initial_points=particles,
            X_train=X_sample,
            y_train=Y_sample,
            kernel_func=kernel_func,
            var_f=var_f_optimized,
            var_n=var_n_optimized,
            lengthscales=l_optimized,
            y_target=y_target,
            n_gen=n_gen_nsga2,
            seed=random_seed + iter_idx
        )

        _, sd_mo = evaluate_particles_with_sd(
            final_solutions,
            (X_sample, Y_sample, kernel_func, var_f_optimized, var_n_optimized, l_optimized)
        )

        final_solutions_all.append(final_solutions)
        final_obj_all.append(final_obj)
        sd_all_iterations_mo.append(sd_mo)

        min_sd_iter = np.min(sd_mo)
        min_sd_all_iterations_mo.append(min_sd_iter)

    return var_f_optimized, var_n_optimized, l_optimized, final_solutions_all, final_obj_all, sd_all_iterations_mo, min_sd_all_iterations_mo


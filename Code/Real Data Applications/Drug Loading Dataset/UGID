def kernel(x1, x2, var_f, lengthscales):
    """
    RBF/Gaussian kernel for d-dimensional data (here d=3).
    x1, x2: shape (N, d), (M, d)
    var_f: scalar (signal variance)
    lengthscales: shape (d,) => length-scales for each dimension
    """
    if x1.ndim == 1:
        x1 = x1.reshape(1, -1)
    if x2.ndim == 1:
        x2 = x2.reshape(1, -1)

    diff = (x1[:, np.newaxis, :] - x2[np.newaxis, :, :]) ** 2
    lengthscales = np.array(lengthscales)  # e.g. shape (3,)
    scaled_diff = diff / (2 * lengthscales**2)
    pairwise_distances = np.sum(scaled_diff, axis=-1)
    return var_f * np.exp(-pairwise_distances)

#GPR Regression + Negative Log Marginal Likelihood

def gp_regression_noisy(X, y, k, x_star, var_f, var_n, l):
    """
    Predictive mean & variance for GPR with noise variance var_n.
    X, y: training data, shape (N, d), (N,)
    x_star: test location(s), shape (M, d)
    var_f: signal variance
    var_n: noise variance
    l: length scales (array)
    """
    # Cov on training
    Kxx = k(X, X, var_f, l) + var_n * np.eye(X.shape[0])
    Lxx = np.linalg.cholesky(Kxx)
    a = np.linalg.solve(Lxx.T, np.linalg.solve(Lxx, y))

    # Cross-cov
    Kxs = k(X, x_star, var_f, l)
    mu = Kxs.T @ a  # predictive mean(s)

    # Predictive var
    v = np.linalg.solve(Lxx, Kxs)
    Kss = k(x_star, x_star, var_f, l)
    var = Kss - v.T @ v

    return mu, var

def f_opt(params, *args):
    """
    Negative log marginal likelihood objective for L-BFGS.
    params = [var_f, l1, l2, ..., var_n]
    """
    X, y, k = args
    d = X.shape[1]
    var_f = params[0]
    var_n = params[-1]
    lengthscales = params[1:-1]

    # Cov with noise
    Kxx = k(X, X, var_f, lengthscales) + var_n*np.eye(X.shape[0])
    Lxx = np.linalg.cholesky(Kxx)
    a = np.linalg.solve(Lxx.T, np.linalg.solve(Lxx, y))
    # Negative log marginal likelihood
    n = X.shape[0]
    logdetK = 2.0 * np.sum(np.log(np.diag(Lxx)))  # log(det(Kxx)) from Cholesky
    return 0.5 * y.T @ a + 0.5 * logdetK + 0.5 * n * np.log(2.0 * np.pi)


def sample_from_unit_cube(n_samples, n_features=6, seed=123):
    np.random.seed(seed)
    return np.random.uniform(0, 1, (n_samples, n_features))

def evaluate_particles_with_sd(particles, gpr_params):
    """
    Evaluate GPR mean & std for each particle.
    Returns predicted_responses, predicted_stds.
    """
    X_sample, Y_sample, kernel_func, var_f, var_n, l = gpr_params
    preds = []
    stds = []
    for p in particles:
        mu, var = gp_regression_noisy(X_sample, Y_sample, kernel_func,
                                      np.array([p]), var_f, var_n, l)
        preds.append(mu[0])
        stds.append(np.sqrt(var[0,0]))
    return np.array(preds).flatten(), np.array(stds).flatten()

def objective_function(x, gpr_params, y_target):
    """
    Objective = (GP mean at x - y_target)^2
    We want to minimize this w.r.t. x in [0,1]^2
    """
    X_sample, Y_sample, kernel_func, var_f, var_n, l = gpr_params
    mu, var = gp_regression_noisy(X_sample, Y_sample, kernel_func,
                                  np.array([x]), var_f, var_n, l)
    return (mu - y_target)**2

def compute_weights(sd, beta):
    """
    Compute weights = exp(-beta * sd) / Z
    """
    w = np.exp(-beta * sd)
    return w / np.sum(w)

def resample_with_noise(particles, weights, covariance_matrix_noise):
    weights = np.array(weights).flatten()  # Ensure weights is 1-dimensional
    n_particles = particles.shape[0]
    n_features = particles.shape[1]

    # Normalize the weights to sum to 1
    weights /= np.sum(weights)

    resampled_indices = np.random.choice(np.arange(n_particles), size=n_particles, p=weights)
    resampled_particles = particles[resampled_indices]

    # Add Gaussian noise to resampled particles using multivariate normal distribution
    noise = np.random.multivariate_normal(mean=np.zeros(n_features), cov=covariance_matrix_noise, size=n_particles)
    noisy_particles = resampled_particles + noise

    # Ensure that the particles remain within [0, 1]^d
    noisy_particles = np.clip(noisy_particles, 0, 1)
    return noisy_particles


def find_beta_with_lbfgs(sd_values, target_fraction, top_percent):
    """
    Example approach to adaptively pick beta.
    Minimizes (fraction(beta) - target_fraction)^2, where fraction is the fraction of total weight
    contributed by top X% of smallest-sd points.
    """
    sd_sorted = np.sort(sd_values)
    n = len(sd_sorted)
    #m = max(1, int(top_percent * n))
    m = max(1, int(np.floor(top_percent * n)))

    def objective(beta_arr):
        beta_val = beta_arr[0] if not np.isscalar(beta_arr) else beta_arr
        numerator = np.sum(np.exp(-beta_val * sd_sorted[:m]))
        denominator = np.sum(np.exp(-beta_val * sd_sorted))
        fraction_val = numerator / (denominator + 1e-14)
        return (fraction_val - target_fraction)**2

    res = opt.minimize(objective, x0=[1.0], method='L-BFGS-B', bounds=[(0,None)])
    beta_opt = res.x[0]
    return beta_opt

def smc_inverse_regression_modified_with_gpr_sd(
    X_sample, Y_sample, kernel_func,
    y_target=15.0,
    K1=1000,
    K2=100,
    random_seed=123,
    n_iterations=50,
    alpha=0.05
):
    """
    6D version of your SMC algorithm with the same steps & structure.
    1) Fit GP with L-BFGS
    2) Sample K1 from [0,1]^6
    3) Evaluate & pick top K2
    4) Local optimization => Step 5
    5) Weighted resampling + noise => Step 10
    """

    # (A) Hyperparameter optimization for GP
    # We'll guess: [var_f, l1, l2, l3, l4, l5, l6, var_n]
    x0 = [1, 0.3, 0.3, 0.3, 0.3, 0.3, 0.3, 0.01]
    # bounds:
    #   var_f >= 1e-3,
    #   each lengthscale in [1e-3, 1.0],
    #   var_n >= 1e-5
    bounds = [(1e-3, None)] + [(1e-3,1.0)]*6 + [(1e-5, None)]
    args = (X_sample, Y_sample, kernel_func)
    res = opt.fmin_l_bfgs_b(f_opt, x0, args=args, approx_grad=True, bounds=bounds)

    var_f_optimized = res[0][0]
    l_optimized = res[0][1:-1]   # shape (6,)
    var_n_optimized = res[0][-1]

    sd_step5_all_iterations = []
    sd_step10_all_iterations = []
    step5_particles_all = []
    final_particles_all = []

    np.random.seed(random_seed)

    for iter_idx in range(n_iterations):
        # Step 1: sample K1 points from [0,1]^6
        particles = sample_from_unit_cube(K1, n_features=6, seed=random_seed + iter_idx)

        # Step 2/3: Evaluate GPR on these & pick top K2
        preds, stds = evaluate_particles_with_sd(
            particles,
            (X_sample, Y_sample, kernel_func, var_f_optimized, var_n_optimized, l_optimized)
        )
        errors = (preds - y_target)**2
        sorted_idx = np.argsort(errors)
        topK_idx = sorted_idx[:K2]
        topK_particles = particles[topK_idx]

        # Step 4: Local optimization on top K2
        for i in range(K2):
            x0_opt = topK_particles[i]
            res_local = minimize(
                objective_function,
                x0_opt,
                args=((X_sample, Y_sample, kernel_func, var_f_optimized, var_n_optimized, l_optimized),
                      y_target),
                bounds=[(0,1)]*topK_particles.shape[1],
                method='L-BFGS-B'
            )
            topK_particles[i] = res_local.x

        # Step 5: measure std dev
        _, sd_step_5 = evaluate_particles_with_sd(
            topK_particles,
            (X_sample, Y_sample, kernel_func, var_f_optimized, var_n_optimized, l_optimized)
        )
        sd_step5_all_iterations.append(sd_step_5)
        step5_particles_all.append(topK_particles)
        min_sd_step5 = np.min(sd_step_5)

        # Step 7: find beta
        beta = find_beta_with_lbfgs(sd_step_5, target_fraction=0.9, top_percent=0.2)
        print(f'Value for Beta at iteration {iter_idx+1}:', beta)

        # Step 8: compute weights
        w = compute_weights(sd_step_5, beta)

        # Step 9: covariance & resample
        if K2 > 1:
            cov_mat = np.cov(topK_particles, rowvar=False)
        else:
            cov_mat = np.eye(6)*1e-8

        cov_mat_noise = alpha * cov_mat
        noisy_particles = resample_with_noise(topK_particles, w, cov_mat_noise)

        # Local optimization on these new points
        for i in range(K2):
            x0_opt = noisy_particles[i]
            res_local = minimize(
                objective_function,
                x0_opt,
                args=((X_sample, Y_sample, kernel_func, var_f_optimized, var_n_optimized, l_optimized),
                      y_target),
                bounds=[(0,1)]*noisy_particles.shape[1],
                method='L-BFGS-B'
            )
            noisy_particles[i] = res_local.x

        # Step 10: measure std dev
        _, sd_step_10 = evaluate_particles_with_sd(
            noisy_particles,
            (X_sample, Y_sample, kernel_func, var_f_optimized, var_n_optimized, l_optimized)
        )
        sd_step10_all_iterations.append(sd_step_10)
        final_particles_all.append(noisy_particles)
        min_sd_step10 = np.min(sd_step_10)

    return (final_particles_all,
            var_f_optimized, l_optimized, var_n_optimized,
            sd_step5_all_iterations, sd_step10_all_iterations,
            step5_particles_all,
            min_sd_step5,
            min_sd_step10)

def get_responses_for_final_particles(final_particles, gpr_params):
    """
    Predict the response values for a set of particles using the GPR model.
    final_particles: array of shape (K2, 2)
    gpr_params: (X_sample, Y_sample, kernel_func, var_f, var_n, l)
    """
    X_sample, Y_sample, kernel_func, var_f, var_n, l = gpr_params
    responses = []
    std_dev_res = []
    for particle in final_particles:
        mu, var = gp_regression_noisy(X_sample, Y_sample, kernel_func,
                                    np.array([particle]), var_f, var_n, l)
        responses.append(mu[0])
        std_dev_res.append(np.sqrt(var[0,0]))
    return np.array(responses), np.array(std_dev_res)


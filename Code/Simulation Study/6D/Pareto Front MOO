)

gpr_params = (X_train, y_train, kernel, var_f, var_n, l)

nds = NonDominatedSorting()

selected_solutions = []
selected_means = []
selected_uncertainties = []

for i in range(n_iterations):
    pop_X = final_solutions_all[i]
    pop_F = final_objectives_all[i]

    non_dom_idx = nds.do(pop_F, only_non_dominated_front=True)
    pareto_solutions_i = pop_X[non_dom_idx]

    pred_means_i, pred_stds_i = evaluate_particles_with_sd(
        pareto_solutions_i,
        gpr_params
    )

    idx_closest = np.argmin(np.abs(pred_means_i - y_target))

    selected_solutions.append(pareto_solutions_i[idx_closest])
    selected_means.append(pred_means_i[idx_closest])
    selected_uncertainties.append(pred_stds_i[idx_closest])

selected_solutions = np.array(selected_solutions)
selected_means = np.array(selected_means)
selected_uncertainties = np.array(selected_uncertainties)


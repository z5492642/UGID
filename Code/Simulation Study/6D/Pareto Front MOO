])

def mean_se(arr):
    arr = np.asarray(arr)
    return float(np.mean(arr)), float(np.std(arr, ddof=1) / np.sqrt(len(arr)))

mean_mu, se_mu = mean_se(pred_means_selected)             # μ(best)
mean_sd, se_sd = mean_se(pred_stds_selected)              # σ(best)
mean_f,  se_f  = mean_se(true_values_selected)            # f(x_sel)
mean_tte, se_tte = mean_se(np.abs(true_values_selected - y_target))  # |f - y*|

lower = pred_means_selected - 1.96 * pred_stds_selected
upper = pred_means_selected + 1.96 * pred_stds_selected
hits  = ((true_values_selected >= lower) & (true_values_selected <= upper)).astype(int)
coverage_95 = np.mean(hits)
se_coverage = np.sqrt(coverage_95 * (1 - coverage_95) / len(hits))

print("Pareto-front Multi-Objective Function method (2D):")
print(f"  μ(best)      = {mean_mu:.4f} (SE {se_mu:.2e})")

plt.ylabel("Predicted value of optimal solution", fontsize=16, labelpad=12)
plt.tick_params(axis='both', which='major', labelsize=16, pad=12)
plt.legend()
plt.show()

feature_names = [f"x{i+1}" for i in range(best_solutions_each_iter.shape[1])]
df_best_solutions = pd.DataFrame(best_solutions_each_iter, columns=feature_names)

sns.pairplot(df_best_solutions, diag_kind="hist", corner=True)
plt.suptitle("Pairwise scatter plots of final solutions", y=1.02, fontsize=16)
plt.show()


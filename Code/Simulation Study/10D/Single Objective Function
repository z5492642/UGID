plt.figure(figsize=(9,7))
plt.scatter(best_particle_stds, best_particle_predictions)
plt.ticklabel_format(useOffset=False, style='plain', axis='both')
plt.axhline(y=y_target, color='r', linestyle='--', label=f'Target={y_target}')
plt.tick_params(axis='both', which='major', labelsize=12)
plt.xlim(0.2, 0.45)
plt.ylim(1.9, 2.1)
